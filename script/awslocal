#!/usr/bin/env bash
# Drop-in replacement for awslocal that routes AWS CLI calls to a local
# SeaweedFS S3 gateway running on port 8333.
set -euo pipefail

export AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID:-test}"
export AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY:-test}"
export AWS_DEFAULT_REGION="${AWS_DEFAULT_REGION:-us-east-1}"

exec aws --endpoint-url "http://localhost:8333" "$@"
